# Node backend environment variables (copy to .env and edit)
PORT=3000
JWT_SECRET=change_this_secret

# SMTP (optional) - leave blank to use demo/no-op sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="IT Support <itsupport@company.com>"

# Microsoft Graph Planner integration (optional)
MS_GRAPH_TOKEN=
PLANNER_PLAN_ID=
PLANNER_BUCKET_ID=
MS_USER_ID=
